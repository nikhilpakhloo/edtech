{
  "expo": {
    "name": "EdStream",
    "slug": "edstream",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/splash-icon.png",
    "scheme": "edstream",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/splash-icon.png",
      "bundleIdentifier": "com.anonymous.EdStream",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "permissions": [
        "VIBRATE"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/splash-icon.png",
        "monochromeImage": "./assets/images/splash-icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.EdStream"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 96,
          "dark": {
            "backgroundColor": "#030712",
            "image": "./assets/images/splash-icon.png"
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "buildToolsVersion": "36.1.0",
            "compileSdkVersion": 36,
            "targetSdkVersion": 36
          }
        }
      ],
      [
        "expo-video",
        {
          "supportsPictureInPicture": true
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#1F80E0",
          "defaultChannel": "study-reminders"
        }
      ],
      "./plugins/withAndroidDynamicAppIcons"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a4078053-6b31-40a2-a06a-82a6a5062050"
      }
    },
    "owner": "nikhilpakhloo"
  }
}
